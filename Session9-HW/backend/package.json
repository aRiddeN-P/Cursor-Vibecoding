{
  "name": "lalayi-backend",
  "version": "1.0.0",
  "description": "Lalayi (لالایی) — Persian children's bedtime storytelling API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:init": "node src/db/init.js",
    "db:reset": "node src/db/reset.js",
    "db:build-stories": "node src/db/build-default-stories.js",
    "seed:stories": "node ../scripts/seed-stories.js"
  },
  "keywords": [
    "lalayi",
    "bedtime",
    "stories"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^2.8.0",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "music-metadata": "^11.13.0",
    "ws": "^8.21.0"
  }
}
